{
  "name": "web",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3000",
    "build": "next build",
    "start": "next start",
    "lint": "eslint --max-warnings 0",
    "check-types": "next typegen && tsc --noEmit",
    "test:e2e": "playwright test -c playwright.config.ts",
    "test:e2e:headed": "playwright test -c playwright.config.ts --headed",
    "test:e2e:debug": "playwright test -c playwright.config.ts --debug",
    "test:e2e:report": "playwright show-report playwright-report",
    "test:e2e:ci": "playwright test -c playwright.config.ts --reporter=line,junit,html"
  },
  "dependencies": {
    "@clerk/nextjs": "^7.0.12",
    "@repo/db": "workspace:*",
    "@repo/reminder": "workspace:*",
    "@repo/ui": "workspace:*",
    "@types/web-push": "^3.6.4",
    "convex": "^1.25.4",
    "next": "16.2.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@playwright/test": "^1.55.1",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^22.15.3",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.39.1",
    "postcss": "^8.5.9",
    "tailwindcss": "^4.2.2",
    "typescript": "5.9.2"
  }
}
