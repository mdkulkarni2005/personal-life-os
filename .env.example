# Personal Life OS environment variables
#
# Copy the runtime values you need into apps/web/.env.local for local development.
# Copy the E2E values into apps/web/.env or apps/web/.env.local if you run Playwright.

# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key
CLERK_JWT_ISSUER_DOMAIN=https://your-clerk-domain.clerk.accounts.dev

# Convex
NEXT_PUBLIC_CONVEX_URL=https://your-convex-deployment.convex.cloud
# Optional fallback if you prefer the server-side alias
CONVEX_URL=https://your-convex-deployment.convex.cloud

# Web Push / VAPID
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_SUBJECT=mailto:reminders@localhost

# App URL used for generated invite links
NEXT_PUBLIC_APP_URL=http://localhost:3000

# AI chat
NVIDIA_NIM_API_KEY=your_nvidia_nim_api_key
NVIDIA_NIM_MODEL=meta/llama-3.1-70b-instruct

# Playwright / E2E
PLAYWRIGHT_BASE_URL=http://localhost:3000
E2E_BASE_URL=http://localhost:3000
E2E_PORT=3100
E2E_TIMEZONE_ID=Asia/Kolkata
E2E_USER_EMAIL=your-test-user-email@example.com
E2E_USER_PASSWORD=your-test-user-password
E2E_SIGNUP_EMAIL=your-signup-test-email@example.com
E2E_SIGNUP_PASSWORD=your-signup-test-password
E2E_SIGNUP_EMAIL_PREFIX=your-signup-prefix
E2E_SIGNUP_EMAIL_DOMAIN=example.com
E2E_SIGNUP_VERIFICATION_CODE=123456
